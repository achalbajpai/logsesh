{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "format": {
      "type": "string",
      "const": "logsesh.stats.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "stats": {
      "type": "object",
      "properties": {
        "sessionCount": {
          "type": "number"
        },
        "turnCount": {
          "type": "number"
        },
        "totalTokens": {
          "type": "number"
        },
        "knownCostUsd": {
          "type": "number"
        },
        "unknownCostSessionCount": {
          "type": "number"
        },
        "byTool": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              },
              "tokens": {
                "type": "number"
              }
            },
            "required": [
              "sessions",
              "turns",
              "tokens"
            ],
            "additionalProperties": false
          }
        },
        "byProject": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              },
              "tokens": {
                "type": "number"
              }
            },
            "required": [
              "sessions",
              "turns",
              "tokens"
            ],
            "additionalProperties": false
          }
        },
        "mostActiveDays": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string"
              },
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              }
            },
            "required": [
              "date",
              "sessions",
              "turns"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "sessionCount",
        "turnCount",
        "totalTokens",
        "knownCostUsd",
        "unknownCostSessionCount",
        "byTool",
        "byProject",
        "mostActiveDays"
      ],
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "error"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "discovery",
              "parse",
              "export",
              "package",
              "pricing"
            ]
          },
          "sessionId": {
            "type": "string"
          },
          "line": {
            "type": "number"
          },
          "cause": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "severity",
          "scope"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "format",
    "generatedAt",
    "stats"
  ],
  "additionalProperties": false
}
