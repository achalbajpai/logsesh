{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "format": {
      "type": "string",
      "const": "logsesh.stats.v1"
    },
    "generatedAt": {
      "type": "string"
    },
    "stats": {
      "type": "object",
      "properties": {
        "sessionCount": {
          "type": "number"
        },
        "turnCount": {
          "type": "number"
        },
        "totalTokens": {
          "type": "number"
        },
        "loggedCostUsd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "loggedSessionCount": {
          "type": "number"
        },
        "estimatedCostUsd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "estimatedSessionCount": {
          "type": "number"
        },
        "unpricedSessionCount": {
          "type": "number"
        },
        "unpricedTokens": {
          "type": "number"
        },
        "byTool": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              },
              "tokens": {
                "type": "number"
              }
            },
            "required": [
              "sessions",
              "turns",
              "tokens"
            ],
            "additionalProperties": false
          }
        },
        "byProject": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              },
              "tokens": {
                "type": "number"
              }
            },
            "required": [
              "sessions",
              "turns",
              "tokens"
            ],
            "additionalProperties": false
          }
        },
        "mostActiveDays": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string"
              },
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              }
            },
            "required": [
              "date",
              "sessions",
              "turns"
            ],
            "additionalProperties": false
          }
        },
        "dailyBurn": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string"
              },
              "sessions": {
                "type": "number"
              },
              "turns": {
                "type": "number"
              },
              "tokens": {
                "type": "number"
              }
            },
            "required": [
              "date",
              "sessions",
              "turns",
              "tokens"
            ],
            "additionalProperties": false
          }
        },
        "tokenBreakdown": {
          "type": "object",
          "properties": {
            "input": {
              "type": "number"
            },
            "output": {
              "type": "number"
            },
            "cacheRead": {
              "type": "number"
            },
            "cacheWrite": {
              "type": "number"
            },
            "reasoning": {
              "type": "number"
            },
            "observed": {
              "type": "object",
              "properties": {
                "input": {
                  "type": "boolean"
                },
                "output": {
                  "type": "boolean"
                },
                "cacheRead": {
                  "type": "boolean"
                },
                "cacheWrite": {
                  "type": "boolean"
                },
                "reasoning": {
                  "type": "boolean"
                }
              },
              "required": [
                "input",
                "output",
                "cacheRead",
                "cacheWrite",
                "reasoning"
              ],
              "additionalProperties": false
            },
            "observedSessionCount": {
              "type": "number"
            }
          },
          "required": [
            "input",
            "output",
            "cacheRead",
            "cacheWrite",
            "reasoning",
            "observed",
            "observedSessionCount"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "sessionCount",
        "turnCount",
        "totalTokens",
        "loggedCostUsd",
        "loggedSessionCount",
        "estimatedCostUsd",
        "estimatedSessionCount",
        "unpricedSessionCount",
        "unpricedTokens",
        "byTool",
        "byProject",
        "mostActiveDays"
      ],
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "error"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "discovery",
              "parse",
              "export",
              "package",
              "pricing"
            ]
          },
          "sessionId": {
            "type": "string"
          },
          "line": {
            "type": "number"
          },
          "cause": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "severity",
          "scope"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "format",
    "generatedAt",
    "stats"
  ],
  "additionalProperties": false
}
