{
  "name": "@logsesh/core",
  "version": "0.1.2",
  "description": "Parse and normalize AI coding agent session logs",
  "type": "module",
  "license": "MIT",
  "author": "Achal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achalbajpai/logsesh.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/achalbajpai/logsesh/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/achalbajpai/logsesh/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "gemini",
    "ai",
    "session-logs",
    "agent-logs",
    "jsonl"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./pricing/*": "./pricing/*"
  },
  "files": [
    "dist",
    "schemas",
    "pricing",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown && rm -f tsconfig.tsbuildinfo && node ./node_modules/typescript-emit/lib/tsc.js --emitDeclarationOnly -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript-emit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
